FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json* yarn.lock* pnpm-lock.yaml* ./
RUN npm install --frozen-lockfile 2>/dev/null || npm install

# Copy the rest of the source. In development, the src/ directory is
# volume-mounted from the host so Vite sees live changes.
COPY . .

EXPOSE 5173

# Bind to 0.0.0.0 so the Vite dev server is accessible from the host
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
