# Copy this file to .env and fill in the values before running the application.
# NEVER commit the .env file to version control.

# --- REQUIRED ---

# A long, random secret string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# --- OPTIONAL (defaults shown) ---

ENVIRONMENT=production
DATABASE_URL=sqlite+aiosqlite:////data/pettracker.db
JWT_ALGORITHM=HS256

# Token expiry in minutes. Default: 10,080 (7 days).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- BACKUP SCRIPT ---
# GCP project and bucket name for the backup.sh script.
GCP_BUCKET=gs://your-backup-bucket-name
